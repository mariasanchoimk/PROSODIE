<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Quiénes somos – Prosodie</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --color-primary:    #0A2540;
      --color-secondary:  #00A8E8;
      --color-accent:     #F26E22;
      --color-light:      #F4F7FB;
      --color-white:      #FFFFFF;
      --color-text:       #1A1A2E;
      --color-text-muted: #5A6A80;
      --color-border:     #D6E0EE;
      --font-main: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
      --radius-sm: 6px;
      --radius-md: 12px;
      --radius-lg: 20px;
      --shadow-sm: 0 2px 8px rgba(10,37,64,0.08);
      --shadow-md: 0 6px 24px rgba(10,37,64,0.13);
      --shadow-dropdown: 0 12px 40px rgba(10,37,64,0.18);
      --transition: 0.25s ease;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-main); color: var(--color-text); background: var(--color-white); line-height: 1.6; font-size: 16px; }
    a { text-decoration: none; color: inherit; }
    ul { list-style: none; }

    /* HEADER */
    .site-header { background: var(--color-primary); position: sticky; top: 0; z-index: 200; box-shadow: 0 2px 12px rgba(0,0,0,0.2); }
    .nav-bar { max-width: 1200px; margin: 0 auto; padding: 0 2rem; height: 70px; display: flex; align-items: center; gap: 1.5rem; }
    .nav-logo { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }
    .nav-logo__mark { width: 36px; height: 36px; background: var(--color-secondary); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; }
    .nav-logo__mark span { color: var(--color-primary); font-weight: 800; font-size: 18px; }
    .nav-logo__text { color: var(--color-white); font-size: 1.25rem; font-weight: 700; letter-spacing: 0.5px; }
    .nav-menu { display: flex; align-items: center; gap: 0; flex: 1; }
    .nav-menu__item { position: relative; }
    .nav-menu__item > a, .nav-menu__item > button { color: rgba(255,255,255,0.85); font-size: 0.875rem; font-weight: 500; padding: 0.55rem 0.9rem; border-radius: var(--radius-sm); transition: var(--transition); display: flex; align-items: center; gap: 0.3rem; background: none; border: none; cursor: pointer; white-space: nowrap; font-family: var(--font-main); line-height: 1; }
    .nav-menu__item > a:hover, .nav-menu__item > button:hover { background: rgba(255,255,255,0.1); color: var(--color-white); }
    .nav-menu__item.active > a, .nav-menu__item.active > button { color: var(--color-secondary); }
    .nav-arrow { width: 12px; height: 12px; stroke: currentColor; fill: none; stroke-width: 2.5; transition: transform var(--transition); flex-shrink: 0; }
    .nav-menu__item.has-dropdown:hover .nav-arrow { transform: rotate(180deg); }
    .nav-dropdown { position: absolute; top: calc(100% + 8px); left: 0; background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-md); box-shadow: var(--shadow-dropdown); min-width: 240px; padding: 0.5rem; opacity: 0; visibility: hidden; transform: translateY(-6px); transition: opacity var(--transition), transform var(--transition), visibility var(--transition); z-index: 300; }
    .nav-menu__item.has-dropdown:hover .nav-dropdown, .nav-menu__item.has-dropdown:focus-within .nav-dropdown { opacity: 1; visibility: visible; transform: translateY(0); }
    .nav-dropdown__item a { display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 0.85rem; border-radius: var(--radius-sm); color: var(--color-text); font-size: 0.875rem; font-weight: 500; transition: var(--transition); }
    .nav-dropdown__item a:hover { background: var(--color-light); color: var(--color-primary); }
    .nav-dropdown__item.active a { background: rgba(0,168,232,0.08); color: var(--color-secondary); }
    .nav-dropdown__icon { width: 32px; height: 32px; background: rgba(0,168,232,0.1); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .nav-dropdown__icon svg { width: 16px; height: 16px; stroke: var(--color-secondary); fill: none; stroke-width: 1.75; }
    .nav-dropdown__label { line-height: 1.2; }
    .nav-dropdown__sub { display: block; font-size: 0.75rem; color: var(--color-text-muted); font-weight: 400; margin-top: 1px; }
    .nav-end { display: flex; align-items: center; gap: 0.75rem; margin-left: auto; flex-shrink: 0; }
    .nav-claim { color: rgba(255,255,255,0.5); font-size: 0.78rem; font-style: italic; white-space: nowrap; }
    .btn-lang { background: transparent; border: 1.5px solid rgba(255,255,255,0.3); color: var(--color-white); font-size: 0.78rem; font-weight: 600; padding: 0.3rem 0.75rem; border-radius: var(--radius-sm); cursor: pointer; transition: var(--transition); }
    .btn-lang:hover { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.6); }
    .btn-contact-nav { background: var(--color-accent); color: var(--color-white); font-size: 0.82rem; font-weight: 700; padding: 0.5rem 1.2rem; border-radius: var(--radius-sm); border: none; cursor: pointer; transition: var(--transition); white-space: nowrap; }
    .btn-contact-nav:hover { background: #d95c10; transform: translateY(-1px); }

    /* UTILIDADES */
    .section-label { display: inline-block; background: rgba(0,168,232,0.1); color: var(--color-secondary); font-size: 0.72rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; padding: 0.3rem 0.8rem; border-radius: 100px; margin-bottom: 1rem; }
    .section-title { font-size: 1.85rem; font-weight: 800; color: var(--color-primary); line-height: 1.25; margin-bottom: 1rem; }

    /* BREADCRUMB */
    .breadcrumb { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.75rem; }
    .breadcrumb a { color: rgba(255,255,255,0.45); font-size: 0.8rem; transition: var(--transition); }
    .breadcrumb a:hover { color: var(--color-secondary); }
    .breadcrumb__sep { color: rgba(255,255,255,0.25); font-size: 0.75rem; }
    .breadcrumb__current { color: rgba(255,255,255,0.7); font-size: 0.8rem; }

    /* =============================================
       BLOQUE 1: HERO / PRESENTACIÓN
    ============================================= */
    .page-hero {
      background: var(--color-primary);
      padding: 5rem 2rem 4.5rem;
      position: relative; overflow: hidden;
    }
    .page-hero::before { content: ''; position: absolute; right: -100px; top: -100px; width: 600px; height: 600px; background: radial-gradient(circle, rgba(0,168,232,0.13) 0%, transparent 70%); pointer-events: none; }
    .page-hero__inner {
      max-width: 1200px; margin: 0 auto; position: relative; z-index: 1;
      display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;
    }
    .page-hero__tag { display: inline-block; background: rgba(0,168,232,0.18); color: var(--color-secondary); font-size: 0.72rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; padding: 0.3rem 0.8rem; border-radius: 100px; margin-bottom: 1.25rem; border: 1px solid rgba(0,168,232,0.3); }
    .page-hero__title { color: var(--color-white); font-size: 2.6rem; font-weight: 800; line-height: 1.12; margin-bottom: 1.25rem; }
    .page-hero__title em { font-style: normal; color: var(--color-secondary); }
    .page-hero__desc { color: rgba(255,255,255,0.7); font-size: 1rem; line-height: 1.8; margin-bottom: 2rem; }
    .btn-hero {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: var(--color-accent); color: var(--color-white);
      font-size: 0.9rem; font-weight: 700; padding: 0.8rem 1.75rem;
      border-radius: var(--radius-sm); transition: var(--transition);
    }
    .btn-hero:hover { background: #d95c10; transform: translateY(-2px); }
    .btn-hero svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 2.5; }

    /* Stats lado derecho del hero */
    .page-hero__stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .hero-stat { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: var(--radius-md); padding: 1.5rem 1.25rem; text-align: center; }
    .hero-stat__number { font-size: 2rem; font-weight: 800; color: var(--color-white); line-height: 1; margin-bottom: 0.35rem; }
    .hero-stat__number span { color: var(--color-secondary); }
    .hero-stat__label { font-size: 0.8rem; color: rgba(255,255,255,0.55); font-weight: 500; }

    /* =============================================
       BLOQUE 2+3: MISIÓN Y VISIÓN
    ============================================= */
    .mission-vision-section { padding: 5.5rem 2rem; background: var(--color-white); }
    .mission-vision-inner { max-width: 1200px; margin: 0 auto; }
    .mission-vision-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }

    .mv-card {
      border-radius: var(--radius-lg); padding: 3rem 2.5rem;
      position: relative; overflow: hidden;
    }
    .mv-card--mission { background: var(--color-primary); }
    .mv-card--vision { background: var(--color-light); border: 1px solid var(--color-border); }

    .mv-card__icon {
      width: 56px; height: 56px; border-radius: var(--radius-md);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1.5rem;
    }
    .mv-card--mission .mv-card__icon { background: rgba(0,168,232,0.15); border: 1px solid rgba(0,168,232,0.25); }
    .mv-card--vision .mv-card__icon { background: rgba(10,37,64,0.08); border: 1px solid var(--color-border); }
    .mv-card__icon svg { width: 26px; height: 26px; fill: none; stroke-width: 1.5; }
    .mv-card--mission .mv-card__icon svg { stroke: var(--color-secondary); }
    .mv-card--vision .mv-card__icon svg { stroke: var(--color-primary); }

    .mv-card__label { font-size: 0.72rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 0.75rem; }
    .mv-card--mission .mv-card__label { color: var(--color-secondary); }
    .mv-card--vision .mv-card__label { color: var(--color-secondary); }

    .mv-card__title { font-size: 1.35rem; font-weight: 800; line-height: 1.3; margin-bottom: 1rem; }
    .mv-card--mission .mv-card__title { color: var(--color-white); }
    .mv-card--vision .mv-card__title { color: var(--color-primary); }

    .mv-card__text { font-size: 0.95rem; line-height: 1.8; }
    .mv-card--mission .mv-card__text { color: rgba(255,255,255,0.68); }
    .mv-card--vision .mv-card__text { color: var(--color-text-muted); }

    /* =============================================
       BLOQUE 4: CIFRAS CLAVE
    ============================================= */
    .kpi-section { padding: 5.5rem 2rem; background: var(--color-light); }
    .kpi-inner { max-width: 1200px; margin: 0 auto; }
    .kpi-header { text-align: center; margin-bottom: 3.5rem; }
    .kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }

    .kpi-card {
      background: var(--color-white); border: 1px solid var(--color-border);
      border-radius: var(--radius-lg); padding: 2rem 1.5rem;
      text-align: center; position: relative; overflow: hidden;
      transition: var(--transition);
    }
    .kpi-card:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }
    .kpi-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--color-secondary); }
    .kpi-card__number { font-size: 2.8rem; font-weight: 800; color: var(--color-primary); line-height: 1; margin-bottom: 0.4rem; }
    .kpi-card__number span { color: var(--color-secondary); }
    .kpi-card__label { font-size: 0.875rem; color: var(--color-text-muted); font-weight: 500; line-height: 1.4; }

    /* =============================================
       BLOQUE 5: HISTORIA (TIMELINE)
    ============================================= */
    .history-section { padding: 5.5rem 2rem; background: var(--color-white); }
    .history-inner { max-width: 1000px; margin: 0 auto; }
    .history-header { text-align: center; margin-bottom: 4rem; }

    .timeline { position: relative; }
    .timeline::before {
      content: ''; position: absolute;
      left: 50%; top: 0; bottom: 0;
      width: 2px; background: var(--color-border);
      transform: translateX(-50%);
    }

    .timeline-item {
      display: grid; grid-template-columns: 1fr 60px 1fr;
      gap: 0; margin-bottom: 3rem; position: relative;
    }
    .timeline-item:last-child { margin-bottom: 0; }

    /* Lado izquierdo (par) */
    .timeline-item:nth-child(odd) .timeline-content { grid-column: 1; text-align: right; padding-right: 2.5rem; }
    .timeline-item:nth-child(odd) .timeline-empty { grid-column: 3; }

    /* Lado derecho (impar) */
    .timeline-item:nth-child(even) .timeline-content { grid-column: 3; text-align: left; padding-left: 2.5rem; }
    .timeline-item:nth-child(even) .timeline-empty { grid-column: 1; }

    /* Punto central */
    .timeline-dot {
      grid-column: 2; grid-row: 1;
      display: flex; align-items: flex-start; justify-content: center;
      padding-top: 4px;
      z-index: 1;
    }
    .timeline-dot__inner {
      width: 44px; height: 44px; border-radius: 50%;
      background: var(--color-primary); border: 3px solid var(--color-white);
      box-shadow: 0 0 0 2px var(--color-secondary);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .timeline-dot__inner span { color: var(--color-secondary); font-size: 0.7rem; font-weight: 800; }

    .timeline-year {
      font-size: 0.72rem; font-weight: 700; letter-spacing: 1px;
      text-transform: uppercase; color: var(--color-secondary);
      margin-bottom: 0.4rem;
    }
    .timeline-title { font-size: 1rem; font-weight: 700; color: var(--color-primary); margin-bottom: 0.5rem; line-height: 1.3; }
    .timeline-desc { font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.7; }

    /* =============================================
       BLOQUE 6: POR QUÉ ELEGIR A PROSODIE
    ============================================= */
    .why-section { padding: 6rem 2rem; background: var(--color-light); }
    .why-inner { max-width: 1200px; margin: 0 auto; }
    .why-header { text-align: center; margin-bottom: 3.5rem; }
    .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
    .why-card {
      background: var(--color-white); border: 1px solid var(--color-border);
      border-radius: var(--radius-lg); padding: 2rem 1.5rem; text-align: center;
      transition: var(--transition); position: relative; overflow: hidden;
    }
    .why-card::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px; background: var(--color-secondary); transform: scaleX(0); transition: var(--transition); }
    .why-card:hover { box-shadow: var(--shadow-md); transform: translateY(-4px); }
    .why-card:hover::after { transform: scaleX(1); }
    .why-card__icon { width: 60px; height: 60px; background: rgba(0,168,232,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.2rem; }
    .why-card__icon svg { width: 28px; height: 28px; stroke: var(--color-secondary); fill: none; stroke-width: 1.5; }
    .why-card__title { font-size: 0.975rem; font-weight: 700; color: var(--color-primary); margin-bottom: 0.65rem; }
    .why-card__desc { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.65; }

    /* =============================================
       BLOQUE 7: EQUIPO DIRECTIVO
    ============================================= */
    .team-section { padding: 5.5rem 2rem; background: var(--color-white); }
    .team-inner { max-width: 1200px; margin: 0 auto; }
    .team-header { text-align: center; margin-bottom: 3.5rem; }
    .team-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }

    .team-card {
      background: var(--color-white); border: 1px solid var(--color-border);
      border-radius: var(--radius-lg); overflow: hidden; transition: var(--transition);
      text-align: center;
    }
    .team-card:hover { box-shadow: var(--shadow-md); transform: translateY(-4px); }

    /* Foto / placeholder */
    .team-card__photo {
      width: 100%; aspect-ratio: 1 / 1;
      background: var(--color-primary); position: relative; overflow: hidden;
    }
    .team-card__photo-bg {
      position: absolute; inset: 0;
      background: repeating-linear-gradient(
        -45deg,
        rgba(255,255,255,0.02) 0px, rgba(255,255,255,0.02) 1px,
        transparent 1px, transparent 14px
      );
    }
    .team-card__photo-icon {
      position: absolute; inset: 0;
      display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem;
    }
    .team-card__photo-icon svg { width: 48px; height: 48px; stroke: rgba(255,255,255,0.25); fill: none; stroke-width: 1; }
    .team-card__photo-label { color: rgba(255,255,255,0.25); font-size: 0.65rem; font-weight: 600; letter-spacing: 0.5px; }

    .team-card__body { padding: 1.25rem 1.25rem 1.5rem; }
    .team-card__name { font-size: 1rem; font-weight: 700; color: var(--color-primary); margin-bottom: 0.3rem; }
    .team-card__role { font-size: 0.82rem; color: var(--color-secondary); font-weight: 600; margin-bottom: 0.65rem; }
    .team-card__linkedin {
      display: inline-flex; align-items: center; gap: 0.35rem;
      color: var(--color-text-muted); font-size: 0.78rem; font-weight: 500;
      transition: var(--transition);
    }
    .team-card__linkedin:hover { color: var(--color-secondary); }
    .team-card__linkedin svg { width: 14px; height: 14px; fill: currentColor; }

    /* =============================================
       CTA
    ============================================= */
    .cta-section { padding: 5rem 2rem; background: var(--color-primary); text-align: center; }
    .cta-inner { max-width: 640px; margin: 0 auto; }
    .cta-section h2 { font-size: 1.9rem; font-weight: 800; color: var(--color-white); margin-bottom: 1rem; }
    .cta-section p { color: rgba(255,255,255,0.65); font-size: 1rem; margin-bottom: 2rem; }
    .cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .btn-cta-primary { background: var(--color-accent); color: var(--color-white); font-size: 0.9rem; font-weight: 700; padding: 0.85rem 2rem; border-radius: var(--radius-sm); transition: var(--transition); }
    .btn-cta-primary:hover { background: #d95c10; transform: translateY(-2px); }
    .btn-cta-secondary { background: rgba(255,255,255,0.1); border: 1.5px solid rgba(255,255,255,0.25); color: var(--color-white); font-size: 0.9rem; font-weight: 700; padding: 0.85rem 2rem; border-radius: var(--radius-sm); transition: var(--transition); }
    .btn-cta-secondary:hover { background: rgba(255,255,255,0.18); }

    /* FOOTER */
    .site-footer { background: var(--color-primary); padding: 3.5rem 2rem 1.5rem; }
    .footer-inner { max-width: 1200px; margin: 0 auto; }
    .footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 3rem; padding-bottom: 3rem; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 1.5rem; }
    .footer-brand__logo { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; }
    .footer-brand__logo-mark { width: 32px; height: 32px; background: var(--color-secondary); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; }
    .footer-brand__logo-mark span { color: var(--color-primary); font-weight: 800; font-size: 16px; }
    .footer-brand__logo-text { color: var(--color-white); font-size: 1.1rem; font-weight: 700; }
    .footer-brand__desc { color: rgba(255,255,255,0.5); font-size: 0.85rem; line-height: 1.7; }
    .footer-col__title { color: var(--color-white); font-size: 0.8rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 1.2rem; }
    .footer-col ul { display: flex; flex-direction: column; gap: 0.6rem; }
    .footer-col ul li a { color: rgba(255,255,255,0.5); font-size: 0.875rem; transition: var(--transition); }
    .footer-col ul li a:hover { color: var(--color-secondary); }
    .footer-contact p { color: rgba(255,255,255,0.5); font-size: 0.875rem; margin-bottom: 0.5rem; }
    .footer-contact strong { color: rgba(255,255,255,0.8); }
    .footer-bottom { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
    .footer-copy { color: rgba(255,255,255,0.35); font-size: 0.8rem; }
    .footer-legal { display: flex; gap: 1.25rem; }
    .footer-legal a { color: rgba(255,255,255,0.35); font-size: 0.8rem; transition: var(--transition); }
    .footer-legal a:hover { color: var(--color-secondary); }

    /* RESPONSIVE */
    @media (max-width: 1024px) {
      .kpi-grid { grid-template-columns: repeat(2, 1fr); }
      .why-grid { grid-template-columns: repeat(2, 1fr); }
      .team-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 900px) {
      .page-hero__inner { grid-template-columns: 1fr; gap: 2.5rem; }
      .mission-vision-grid { grid-template-columns: 1fr; }
      .timeline::before { left: 22px; }
      .timeline-item { grid-template-columns: 44px 1fr; }
      .timeline-item:nth-child(odd) .timeline-content,
      .timeline-item:nth-child(even) .timeline-content { grid-column: 2; text-align: left; padding-left: 1.5rem; padding-right: 0; }
      .timeline-dot { grid-column: 1; }
      .timeline-item:nth-child(odd) .timeline-empty,
      .timeline-item:nth-child(even) .timeline-empty { display: none; }
      .nav-claim { display: none; }
      .footer-top { grid-template-columns: 1fr 1fr; gap: 2rem; }
    }
    @media (max-width: 768px) {
      .nav-menu { display: none; }
      .page-hero__title { font-size: 2rem; }
      .team-grid { grid-template-columns: repeat(2, 1fr); }
      .kpi-grid { grid-template-columns: repeat(2, 1fr); }
      .footer-top { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      .team-grid { grid-template-columns: 1fr 1fr; }
      .footer-bottom { flex-direction: column; text-align: center; }
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="site-header">
    <nav class="nav-bar" aria-label="Navegación principal">
      <a href="index.html" class="nav-logo" aria-label="Prosodie – Inicio">
        <div class="nav-logo__mark"><span>P</span></div>
